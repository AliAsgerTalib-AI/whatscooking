{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "checkJs": true,
    "allowJs": true,
    "strict": false,
    "noImplicitAny": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@/types/*":      ["./src/types/*"],
      "@/data/*":       ["./src/data/*"],
      "@/utils/*":      ["./src/utils/*"],
      "@/api/*":        ["./src/api/*"],
      "@/export/*":     ["./src/export/*"],
      "@/components/*": ["./src/components/*"]
    }
  },
  "include": [
    "RecipeGenerator.jsx",
    "src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
